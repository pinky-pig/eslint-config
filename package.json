{
  "name": "@arvinn/eslint-config",
  "version": "0.0.9",
  "packageManager": "pnpm@10.12.4",
  "description": "ESLint config for @arvinn.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/pinky-pig/use/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/pinky-pig/use/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinky-pig/use.git"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "up": "taze major -I",
    "setup": "pnpm run build:typegen",
    "dev": "npx @eslint/config-inspector@latest",
    "build": "pnpm run build:typegen && tsdown",
    "build:typegen": "tsx scripts/typegen.ts",
    "build:eslint-inspector": "eslint-config-inspector build --config eslint-inspector.config.ts",
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "eslint": "^8.56.0 || ^9.0.0"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@eslint/markdown": "^6.6.0",
    "@unocss/eslint-plugin": "^66.3.2",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-flat-config-utils": "^2.1.0",
    "eslint-plugin-antfu": "^3.1.1",
    "eslint-plugin-command": "^3.3.1",
    "eslint-plugin-de-morgan": "^1.3.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsdoc": "^51.2.3",
    "eslint-plugin-jsonc": "^2.20.1",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-n": "^17.20.0",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-pnpm": "^0.3.1",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-regexp": "^2.9.0",
    "eslint-plugin-unicorn": "^59.0.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^10.2.0",
    "eslint-plugin-yml": "^1.18.0",
    "globals": "^16.2.0",
    "jiti": "^2.4.2",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^1.1.1",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.35.0",
    "vue-eslint-parser": "^10.1.4",
    "yaml-eslint-parser": "^1.3.0"
  },
  "devDependencies": {
    "@arvinn/prettier-config": "^0.0.3",
    "@eslint/config-inspector": "^1.1.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^20.19.2",
    "ansis": "^4.1.0",
    "bumpp": "^10.2.0",
    "configs": "link:@eslint-community/eslint-plugin-eslint-comments/configs",
    "eslint": "^9.30.0",
    "eslint-typegen": "^2.2.0",
    "taze": "^19.1.0",
    "tsdown": "^0.12.9",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": "^18.18.0 || >=20.0.0"
  },
  "prettier": "./prettierrc.cjs"
}
